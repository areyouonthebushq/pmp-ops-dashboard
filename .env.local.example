# Supabase — copy to .env.local and fill in (or set in Vercel dashboard)
# For static HTML, these are not read automatically; use a build step to inject into index.html
# or set window.SUPABASE_URL / window.SUPABASE_ANON_KEY in a script tag.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
